# Environment Configuration Example
# Copy this file to .env and fill in your own API keys

# OpenAI API key (required for GPT-4o semantic column tagging in section 4.3)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Claude API key (optional - for alternative LLM experiments)
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=your-claude-api-key-here

# Google API key (optional - for additional AI services)
# Get your key at: https://cloud.google.com/docs/authentication
GOOGLE_API_KEY=your-google-api-key-here

# Note: NEVER commit the .env file to version control
# The .env-example file shows the required environment variables without revealing secrets
